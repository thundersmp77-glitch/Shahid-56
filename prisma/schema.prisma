generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  orders    Order[]
  reviews   Review[]
}

model Plan {
  id          String   @id @default(cuid())
  name        String
  type        String   // PlanType: VPS, VDS, MINECRAFT
  ram         String   // e.g. "8 GB"
  cpu         String   // e.g. "4 vCores"
  storage     String   // e.g. "100 GB SSD"
  priceINR    Float
  features    String   // JSON array of strings
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
}

model Order {
  id              String     @id @default(cuid())
  userId          String
  planId          String
  status          String     @default("PENDING") // OrderStatus: PENDING, APPROVED, REJECTED
  amountINR       Float
  transactionId   String?
  screenshotUrl   String?    // relative path /uploads/orders/xxx.jpg
  email           String
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user            User       @relation(fields: [userId], references: [id])
  plan            Plan       @relation(fields: [planId], references: [id])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  username  String
  message   String
  rating    Int      // 1–5
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model Settings {
  id               String  @id @default("global")
  discordWebhook   String?
  panelUrl         String  @default("https://panel.syntaxhost.com")
  discordUrl       String  @default("https://discord.gg/V5tVyazx4H")
  youtubeUrl       String  @default("https://youtube.com/@syntaxhost")
  instagramUrl     String  @default("https://instagram.com/syntaxhost")
  supportEmail     String  @default("support@syntaxhost.com")
  resellerClubKey  String?
  nameComKey       String?
}

model News {
  id        String   @id @default(cuid())
  title     String
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
